#!/bin/bash
#
# pre-commit hook for cmux
#
# This hook enforces the dev cycle governance rule (2026-03-10):
# 1. Run `bun check` before commit
# 2. If check fails, block the commit
# 3. If check passes but changes exist, suggest /simplify
#
# To enable: git config core.hooksPath .githooks
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}Running pre-commit checks...${NC}"

# Run bun check
if ! bun check; then
    echo ""
    echo -e "${RED}Pre-commit check failed.${NC}"
    echo -e "${YELLOW}Fix the issues above and try again.${NC}"
    echo ""
    echo "Common fixes:"
    echo "  - TypeScript errors: fix type issues in the reported files"
    echo "  - ESLint errors: fix lint issues or run 'bun run lint --fix'"
    echo ""
    exit 1
fi

echo -e "${GREEN}bun check passed.${NC}"

# Check if there are unstaged changes after the check
# (This can happen if bun check auto-fixes something)
UNSTAGED=$(git diff --name-only 2>/dev/null || true)
if [ -n "$UNSTAGED" ]; then
    echo ""
    echo -e "${YELLOW}Note: There are unstaged changes after running checks:${NC}"
    echo "$UNSTAGED" | head -10
    echo ""
    echo -e "${YELLOW}Consider running /simplify to review and clean up these changes.${NC}"
    echo "  Run: /simplify"
    echo "  Or:  ./scripts/check-and-simplify.sh"
    echo ""
    echo -e "${BLUE}Proceeding with commit (you can simplify later).${NC}"
fi

# Check for large files being committed
LARGE_FILES=$(git diff --cached --name-only | while read file; do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file" 2>/dev/null || echo 0)
        if [ "$size" -gt 1000000 ]; then
            echo "$file ($(( size / 1024 ))KB)"
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo ""
    echo -e "${YELLOW}Warning: Large files are being committed:${NC}"
    echo "$LARGE_FILES"
    echo ""
fi

# Check for sensitive patterns (basic check)
SENSITIVE_PATTERNS="ANTHROPIC_API_KEY|OPENAI_API_KEY|AWS_SECRET|PRIVATE_KEY|password.*=|api_key.*="
SENSITIVE_FILES=$(git diff --cached --name-only | while read file; do
    if [ -f "$file" ] && [[ "$file" != *.md ]] && [[ "$file" != .env* ]]; then
        if grep -qiE "$SENSITIVE_PATTERNS" "$file" 2>/dev/null; then
            echo "$file"
        fi
    fi
done)

if [ -n "$SENSITIVE_FILES" ]; then
    echo ""
    echo -e "${RED}Warning: Possible sensitive data in staged files:${NC}"
    echo "$SENSITIVE_FILES"
    echo ""
    echo -e "${YELLOW}Please review these files before committing.${NC}"
fi

echo -e "${GREEN}Pre-commit checks complete.${NC}"
exit 0
