# =============================================================================
# cmux Coolify Deployment Environment Variables
# =============================================================================
# Copy this file and set values in Coolify UI or .env file.
# Required variables are marked with (REQUIRED).

# ── Docker Images ─────────────────────────────────────────────────────────────
# Override to use specific image tags (defaults to :latest)
# CLIENT_IMAGE=ghcr.io/karlorz/cmux-client:latest
# WWW_IMAGE=ghcr.io/karlorz/cmux-www:latest
# SERVER_IMAGE=ghcr.io/karlorz/cmux-server:latest

# ── Service Ports ─────────────────────────────────────────────────────────────
# CLIENT_PORT=8080
# WWW_PORT=9779
# SERVER_PORT=9776

# ── Timezone ──────────────────────────────────────────────────────────────────
# TZ=Asia/Hong_Kong

# ── Convex (REQUIRED) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_SITE_URL=https://your-deployment.convex.site

# ── Stack Auth (REQUIRED for www) ─────────────────────────────────────────────
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=
# STACK_SUPER_SECRET_ADMIN_KEY=
# STACK_DATA_VAULT_SECRET=

# ── Origins (REQUIRED) ────────────────────────────────────────────────────────
# Your production domains
NEXT_PUBLIC_WWW_ORIGIN=https://www.cmux.sh
NEXT_PUBLIC_CLIENT_ORIGIN=https://app.cmux.sh
NEXT_PUBLIC_SERVER_ORIGIN=https://server.cmux.sh

# ── Internal service routing (RECOMMENDED for server) ─────────────────────────
# Public server URL used for agent-to-server API calls and external callbacks
CMUX_SERVER_URL=https://server.cmux.sh
# Internal URL for server -> www API calls when both services share one network
WWW_INTERNAL_URL=http://cmux-www:9779

# ── CORS (REQUIRED for server) ────────────────────────────────────────────────
# Comma-separated list of allowed origins for WebSocket connections
CMUX_ALLOWED_SOCKET_ORIGINS=https://app.cmux.sh,https://www.cmux.sh

# ── JWT Secret (REQUIRED) ─────────────────────────────────────────────────────
# Shared secret for agent-to-agent authentication
CMUX_TASK_RUN_JWT_SECRET=your-secure-jwt-secret-min-32-chars

# ── GitHub App (Optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GITHUB_APP_SLUG=cmux
# CMUX_GITHUB_APP_ID=
# CMUX_GITHUB_APP_PRIVATE_KEY=

# ── Sandbox Providers (Optional) ──────────────────────────────────────────────
# MORPH_API_KEY=
# E2B_API_KEY=
# PVE_API_URL=
# PVE_API_TOKEN=

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB_MODE=true

# ── Phase 2: Operator Visual Verification ─────────────────────────────────────
# Set to "true" to enable automatic screenshots after task completion
# CMUX_ENABLE_OPERATOR_VERIFICATION=true
