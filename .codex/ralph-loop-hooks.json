{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); exec \"$ROOT\"/.codex/hooks/ralph-loop-stop.sh'",
            "timeout": 30,
            "statusMessage": "running ralph loop stop hook"
          }
        ]
      }
    ]
  }
}
