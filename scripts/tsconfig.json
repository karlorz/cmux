{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "outDir": "dist",
    "allowImportingTsExtensions": true,
    "paths": {
      "@cmux/*": ["./packages/*"]
    }
  },
  "include": ["./**/*"],
  "exclude": [
    "node_modules",
