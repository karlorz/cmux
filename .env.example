# =============================================================================
# cmux .env.example
# =============================================================================

# ── Stack Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=
STACK_SUPER_SECRET_ADMIN_KEY=
STACK_WEBHOOK_SECRET=
STACK_DATA_VAULT_SECRET=           # min 32 chars

# ── Convex ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=

# ── App URLs ─────────────────────────────────────────────────────────────────
BASE_APP_URL=
NEXT_PUBLIC_WWW_ORIGIN=
# NEXT_PUBLIC_SERVER_ORIGIN=

# ── Internal Service URLs (Coolify/Docker Compose) ───────────────────────────
# Server URL for agent-to-server API calls (e.g., spawn_agent MCP tool).
# In Coolify: http://cmux-server:9776 or your server's internal hostname.
# CMUX_SERVER_URL=http://localhost:9776

# Internal URL for server→www API calls on the same machine.
# Bypasses Cloudflare tunnel to avoid 524 timeout on long-running requests.
# In Coolify: http://cmux-www:9779 or your www service's internal hostname.
# WWW_INTERNAL_URL=http://localhost:9779

# ── GitHub App ───────────────────────────────────────────────────────────────
CMUX_GITHUB_APP_ID=
CMUX_GITHUB_APP_PRIVATE_KEY=
# NEXT_PUBLIC_GITHUB_APP_SLUG=
# GITHUB_APP_WEBHOOK_SECRET=
# INSTALL_STATE_SECRET=

# ── AI Provider Keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# VERTEX_PRIVATE_KEY=
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_REGION=

# ── Sandbox Providers ───────────────────────────────────────────────────────
MORPH_API_KEY=
# E2B_API_KEY=
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# MODAL_SNAPSHOT_IMAGE_ID=

# ── Internal / Auth ─────────────────────────────────────────────────────────
CMUX_TASK_RUN_JWT_SECRET=

# ── Analytics ────────────────────────────────────────────────────────────────
# POSTHOG_API_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# ── Host Overrides (defaults shown) ─────────────────────────────────────────
# CMUX_HOST_CLIENT=localhost:5173
# CMUX_HOST_SERVER=localhost:9779
# CMUX_HOST_VSCODE=localhost:39377
# CMUX_HOST_OPENCODE=127.0.0.1
# CMUX_HOST_AMP_PROXY=localhost
# CMUX_HOST_SANDBOX_API=localhost:46833
# NEXT_PUBLIC_CMUX_HOST_CLIENT=localhost:5173
# NEXT_PUBLIC_CMUX_HOST_SERVER=localhost:9779

# ── Feature Flags ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_WEB_MODE=false
# CMUX_IS_STAGING=
# CONVEX_IS_PRODUCTION=

# ── Phase 2: Operator Visual Verification ─────────────────────────────────────
# Set to "true" to enable automatic screenshots after task run completion.
# Requires: magnitude-core browser automation, Chrome CDP ports exposed.
# CMUX_ENABLE_OPERATOR_VERIFICATION=true

# ── Phase 1: PR Comment → Agent ───────────────────────────────────────────────
# No env var needed - enabled by default in code.
# Requires: GitHub App must have `issue_comment` event enabled in settings.
# Users mention @cmux in PR comments to trigger agents.
