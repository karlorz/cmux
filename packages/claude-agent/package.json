{
  "name": "@cmux/claude-agent",
  "version": "0.1.0",
  "description": "cmux wrapper for Claude Agent SDK - route sub-agent execution to remote sandboxes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "claude",
    "anthropic",
    "agent",
    "sdk",
    "cmux",
    "sandbox",
    "orchestration"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "execa": "^9.5.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
